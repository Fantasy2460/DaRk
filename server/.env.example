# 数据库（开发阶段默认 SQLite，可改为 PostgreSQL）
# SQLite: file:./dev.db
# PostgreSQL: postgresql://user:password@localhost:5432/dark_journey?schema=public
DATABASE_URL="file:./dev.db"

# JWT 密钥（生产环境请更换为强随机字符串）
JWT_SECRET="dark-journey-dev-secret-change-me"
JWT_EXPIRES_IN="7d"

# 服务器端口
PORT=3001

# CORS 白名单（开发时前端地址）
CLIENT_URL="http://localhost:5173"
